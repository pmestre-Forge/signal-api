# Wallet address to receive USDC payments (Base L2)
EVM_ADDRESS=0xYourWalletAddressHere

# Network: eip155:84532 for Base Sepolia testnet, eip155:8453 for Base mainnet
NETWORK=eip155:84532

# Facilitator: https://x402.org/facilitator for testnet, production uses CDP
FACILITATOR_URL=https://x402.org/facilitator

# For production, get these from https://portal.cdp.coinbase.com/
# CDP_API_KEY_ID=
# CDP_API_KEY_SECRET=

# Signal pricing (USD)
PRICE_SIGNAL=0.005
PRICE_SCAN=0.01
PRICE_RISK=0.01
